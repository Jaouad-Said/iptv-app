---
import Page from '../../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import { LOCALES } from '../../../config/locales';
import { SITE } from '../../../config/site';
import Breadcrumbs from '../../../components/nav/Breadcrumbs.astro';
import type { Locale } from '../../../config/locales';

export async function getStaticPaths() {
  return LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };

const allPosts = await getCollection('blog', p =>
  !p.data.draft && p.data.lang === lang
);
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Page
  lang={lang}
  title="Blog"
  description={`Read the latest articles about IPTV, streaming, and entertainment from ${SITE.name}.`}
  canonicalPath="/blog"
  waMessageKey="default"
>
  <Breadcrumbs lang={lang} items={[{ label: 'Blog' }]} />
  <div class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-800 dark:text-slate-100 mb-10">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-slate-500 dark:text-slate-400">No posts yet. Check back soon!</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {posts.map(post => (
          <a
            href={`/${lang}/blog/${post.slug.split('/').pop()}`}
            class="group block rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900
                   p-6 hover:border-[#3B82F6]/40 hover:shadow-[var(--shadow-card)] transition-all duration-200"
          >
            <div class="flex gap-2 flex-wrap mb-3">
              {post.data.tags.map(tag => (
                <span class="px-2 py-0.5 rounded-full bg-[#3B82F6]/10 text-[#3B82F6] text-xs font-medium">{tag}</span>
              ))}
            </div>
            <h2 class="font-bold text-slate-800 dark:text-slate-100 group-hover:text-[#3B82F6] transition-colors duration-150 mb-2">
              {post.data.title}
            </h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">{post.data.description}</p>
            <time class="mt-3 block text-xs text-slate-400" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    )}
  </div>
</Page>
