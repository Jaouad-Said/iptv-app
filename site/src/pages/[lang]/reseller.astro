---
import Page from '../../layouts/Page.astro';
import ContactCTA from '../../components/sections/ContactCTA.astro';
import { SITE } from '../../config/site';
import { LOCALES } from '../../config/locales';
import { useTranslations } from '../../i18n/index';
import { getWhatsAppUrl } from '../../config/whatsapp';
import Breadcrumbs from '../../components/nav/Breadcrumbs.astro';
import type { Locale } from '../../config/locales';

export function getStaticPaths() {
  return LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
const resellerT = t('reseller');
const waUrl = getWhatsAppUrl('reseller');

const RESELLER_TIERS = [
  {
    tier: 'diamond',
    color: '#B9F2FF',
    darkBg: 'from-blue-950 to-slate-950',
    packages: [
      { name: 'Starter', credits: 5, price: 200 },
      { name: 'Professional', credits: 10, price: 350, bestSeller: true },
      { name: 'Business', credits: 20, price: 599 },
    ],
  },
  {
    tier: 'gold',
    color: '#FFD700',
    darkBg: 'from-yellow-950 to-slate-950',
    packages: [
      { name: 'Starter', credits: 5, price: 150 },
      { name: 'Professional', credits: 10, price: 250, bestSeller: true },
      { name: 'Business', credits: 20, price: 399 },
    ],
  },
];

const WHY_FEATURES = [
  { icon: '💰', title: 'Affordable entry from €250', desc: 'Simple credit system, no monthly fees.' },
  { icon: '🖥️', title: 'Powerful servers & top quality', desc: 'Modern, reliable infrastructure.' },
  { icon: '📅', title: 'Trusted provider', desc: `Active since ${SITE.foundedYear} with a proven track record.` },
  { icon: '🎧', title: '24/7 expert support', desc: 'Round-the-clock dedicated reseller assistance.' },
];
---

<Page
  lang={lang}
  title={resellerT.title}
  description={resellerT.subtitle}
  canonicalPath="/reseller"
  waMessageKey="reseller"
>
  <Breadcrumbs lang={lang} items={[{ label: t('nav').reseller }]} />
  <!-- Hero -->
  <section class="py-20 px-4 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block px-3 py-1 rounded-full border border-[#3B82F6]/30 bg-[#3B82F6]/10 text-[#3B82F6] text-xs font-bold uppercase tracking-wider mb-6">
        {SITE.name} Reseller Program
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">{resellerT.title}</h1>
      <p class="text-lg text-slate-300 mb-10 max-w-2xl mx-auto">{resellerT.subtitle}</p>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-[#25D366] text-white font-semibold
               hover:brightness-110 hover:scale-105 transition-all duration-200 shadow-lg"
      >
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {resellerT.cta_primary}
      </a>
    </div>
  </section>

  <!-- Why Resell -->
  <section class="py-16 px-4 bg-white dark:bg-slate-950">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-800 dark:text-slate-100 text-center mb-10">
        {resellerT.why_title}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {WHY_FEATURES.map(f => (
          <div class="p-5 rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
            <span class="text-2xl mb-3 block">{f.icon}</span>
            <h3 class="font-bold text-slate-800 dark:text-slate-100 text-sm mb-1">{f.title}</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reseller Packages -->
  <section class="py-16 px-4 bg-slate-50 dark:bg-slate-900/30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-800 dark:text-slate-100 text-center mb-3">
        {resellerT.packages_title}
      </h2>
      <p class="text-center text-sm text-slate-500 dark:text-slate-400 mb-10">{resellerT.credit_note}</p>

      {RESELLER_TIERS.map(tierData => (
        <div class="mb-12">
          <h3 class="text-lg font-bold text-slate-700 dark:text-slate-200 mb-5 flex items-center gap-2">
            <span style={`color: ${tierData.color}`}>★</span>
            {resellerT.tiers[tierData.tier as 'diamond' | 'gold']}
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
            {tierData.packages.map(pkg => (
              <div class:list={[
                'relative p-6 rounded-2xl border bg-white dark:bg-slate-900',
                pkg.bestSeller
                  ? 'border-[#3B82F6] shadow-[0_0_0_1px_#3B82F6]'
                  : 'border-slate-200 dark:border-slate-800',
              ]}>
                {pkg.bestSeller && (
                  <div class="absolute -top-3 start-1/2 -translate-x-1/2 rtl:translate-x-1/2">
                    <span class="px-3 py-1 rounded-full bg-[#3B82F6] text-white text-xs font-bold shadow-md whitespace-nowrap">
                      BEST SELLER
                    </span>
                  </div>
                )}
                <p class="font-bold text-slate-800 dark:text-slate-100 mb-1">{pkg.name}</p>
                <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">{pkg.credits} Credits</p>
                <p class="text-3xl font-extrabold text-slate-800 dark:text-slate-100 mb-4">
                  €{pkg.price}
                </p>
                <ul class="space-y-1.5 mb-5">
                  {[resellerT.credits_never_expire, resellerT.free_trials, resellerT.own_panel, resellerT.all_features].map(f => (
                    <li class="flex items-center gap-2 text-xs text-slate-600 dark:text-slate-300">
                      <svg class="w-3.5 h-3.5 text-[#3B82F6] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <a
                  href={waUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    'flex items-center justify-center gap-2 w-full py-2.5 rounded-full text-sm font-semibold transition-all duration-150',
                    pkg.bestSeller
                      ? 'bg-[#3B82F6] text-white hover:brightness-110'
                      : 'border border-[#3B82F6] text-[#3B82F6] hover:bg-[#3B82F6] hover:text-white',
                  ]}
                >
                  {resellerT.cta_primary}
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <ContactCTA lang={lang} />
</Page>
