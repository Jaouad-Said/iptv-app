// ─── 6. TRANSLATIONS ──────────────────────────────────────────────────────────
function renderTranslations(): HTMLElement {
  const langs: ('en' | 'fr' | 'ar')[] = ['en', 'fr', 'ar'];
  let langIdx = 0;
  const collapsed: Record<string, boolean> = {};
  const wrap = h('div', { className: 'space-y-4' });

  function rebuild() {
    wrap.innerHTML = '';
    wrap.appendChild(tabs(['EN', 'FR', 'AR'], langIdx, i => { langIdx = i; rebuild(); }));

    const lang = langs[langIdx];
    const t = state.translations[lang];

    const dlBtn = h('button', { className: btnCls + ' mb-4 bg-slate-700', onClick: () => downloadFile(`${lang}.ts`, generateTranslationTs(lang)) }, `Download ${lang}.ts`);
    wrap.appendChild(dlBtn);

    const sections = Object.keys(t) as string[];
    sections.forEach(section => {
      const sectionData = (t as any)[section];
      const isOpen = !collapsed[`${lang}.${section}`];

      const header = h('button', {
        className: 'w-full flex items-center justify-between px-4 py-3 bg-slate-800 rounded-lg border border-slate-700 text-left hover:bg-slate-750 transition-colors',
        onClick: () => { collapsed[`${lang}.${section}`] = isOpen; rebuild(); }
      });
      const arrow = h('span', { className: `text-slate-400 transition-transform ${isOpen ? 'rotate-180' : ''}` });
      arrow.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>';
      header.append(h('span', { className: 'text-sm font-semibold text-white' }, section), arrow);
      wrap.appendChild(header);

      if (isOpen) {
        const body = h('div', { className: 'bg-slate-800/30 border border-slate-700 border-t-0 rounded-b-lg p-4 mb-2 space-y-3' });
        renderTranslationFields(body, sectionData, `translations.${lang}.${section}`, lang, section);
        wrap.appendChild(body);
      }
    });
  }

  function renderTranslationFields(container: HTMLElement, data: any, basePath: string, lang: string, section: string) {
    if (data === null || data === undefined) return;

    if (typeof data === 'string') {
      container.appendChild(field(basePath.split('.').pop()!, textInput(data, v => {
        setNestedValue(state, basePath, v);
      })));
      return;
    }

    if (typeof data === 'number') {
      container.appendChild(field(basePath.split('.').pop()!, numberInput(data, v => {
        setNestedValue(state, basePath, v);
      })));
      return;
    }

    if (Array.isArray(data)) {
      const arrLabel = basePath.split('.').pop()!;
      container.appendChild(h('h4', { className: 'text-sm font-semibold text-slate-300 mt-2' }, arrLabel + ' (array)'));

      data.forEach((item: any, idx: number) => {
        const itemPath = `${basePath}.${idx}`;
        const row = h('div', { className: 'ml-4 border-l-2 border-slate-700 pl-4 mb-3 relative' });

        const removeBtn = h('button', { className: btnDangerCls + ' absolute top-0 right-0', onClick: () => {
          data.splice(idx, 1);
          rebuild();
          toast('Item removed');
        }}, 'X');
        row.appendChild(removeBtn);

        if (typeof item === 'string') {
          row.appendChild(textInput(item, v => { data[idx] = v; }));
        } else if (typeof item === 'object' && item !== null) {
          Object.keys(item).forEach(key => {
            const val = item[key];
            const keyPath = `${itemPath}.${key}`;
            if (typeof val === 'string') {
              row.appendChild(field(key, textInput(val, v => { item[key] = v; })));
            } else if (typeof val === 'number') {
              row.appendChild(field(key, numberInput(val, v => { item[key] = v; })));
            } else if (val === null) {
              row.appendChild(field(key + ' (null or string)', textInput('', v => { item[key] = v || null; })));
            }
          });
        }
        container.appendChild(row);
      });

      // Add button
      const addBtn = h('button', { className: btnSmCls + ' ml-4 mt-1', onClick: () => {
        if (data.length > 0) {
          const template = clone(data[0]);
          if (typeof template === 'string') {
            data.push('');
          } else if (typeof template === 'object' && template !== null) {
            // Clear all string values
            for (const key of Object.keys(template)) {
              if (typeof template[key] === 'string') template[key] = '';
              else if (typeof template[key] === 'number') template[key] = 0;
            }
            data.push(template);
          }
        } else {
          data.push('');
        }
        rebuild();
        toast('Item added');
      }}, '+ Add Item');
      container.appendChild(addBtn);
      return;
    }

    if (typeof data === 'object') {
      Object.keys(data).forEach(key => {
        const val = data[key];
        const keyPath = `${basePath}.${key}`;

        if (typeof val === 'string') {
          container.appendChild(field(key, textInput(val, v => { data[key] = v; })));
        } else if (typeof val === 'number') {
          container.appendChild(field(key, numberInput(val, v => { data[key] = v; })));
        } else if (val === null) {
          container.appendChild(field(key + ' (null or string)', textInput('', v => { data[key] = v || null; })));
        } else if (Array.isArray(val) || typeof val === 'object') {
          const sub = h('div', { className: 'mt-3 mb-2' });
          renderTranslationFields(sub, val, keyPath, lang, section);
          container.appendChild(sub);
        }
      });
    }
  }

  rebuild();
  return wrap;
}

