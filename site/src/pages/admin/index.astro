    wrap.innerHTML = '';

    state.blogPosts.forEach((post: any, idx: number) => {
      const card = h('div', { className: cardCls + ' relative' });
      const removeBtn = h('button', { className: btnDangerCls + ' absolute top-3 right-3', onClick: () => {
        state.blogPosts.splice(idx, 1); rebuild(); toast('Post removed');
      }}, 'Remove');

      const grid = h('div', { className: 'grid grid-cols-1 md:grid-cols-2 gap-4' });
      grid.append(
        field('Title', textInput(post.title, v => post.title = v)),
        field('Description', textInput(post.description, v => post.description = v)),
        field('Author', textInput(post.author, v => post.author = v)),
        field('Tags (comma-separated)', textInput((post.tags || []).join(', '), v => post.tags = v.split(',').map((t: string) => t.trim()).filter(Boolean))),
        field('Canonical Slug', textInput(post.canonicalSlug || '', v => post.canonicalSlug = v)),
        field('Language', selectInput(
          [{ value: 'en', label: 'English' }, { value: 'fr', label: 'French' }, { value: 'ar', label: 'Arabic' }],
          post.lang, v => post.lang = v
        )),
        field('Publication Date', textInput(post.pubDate ? post.pubDate.split('T')[0] : '', v => post.pubDate = v)),
      );

      const draftToggle = h('div', { className: 'flex items-center gap-3' },
        h('span', { className: 'text-sm text-slate-300' }, 'Draft'),
        toggleSwitch(!!post.draft, v => post.draft = v)
      );
      grid.appendChild(h('div', { className: 'flex items-end' }, draftToggle));

      card.append(
        removeBtn,
        h('h3', { className: 'text-lg font-semibold text-white mb-3' }, post.title || 'Untitled Post'),
        grid,
        field('Body (Markdown)', textareaInput(post.body || '', v => post.body = v, 10))
      );
      wrap.appendChild(card);
    });

    const addBtn = h('button', { className: btnCls, onClick: () => {
      state.blogPosts.push({
        slug: `en/new-post-${Date.now()}`,
        title: 'New Post',
        description: '',
        author: 'Admin',
        tags: [],
        lang: 'en',
        draft: true,
        canonicalSlug: 'new-post',
        pubDate: new Date().toISOString(),
        updatedDate: null,
        body: '## New Post\n\nWrite your content here.',
      });
      rebuild(); toast('Blog post added');
    }}, '+ Add New Post');

    const dlBtn = h('button', { className: btnCls + ' ml-2 bg-slate-700', onClick: () => {
      state.blogPosts.forEach((post: any) => {
        const md = generateBlogMd(post);
        const filename = `${post.lang}/${post.canonicalSlug || 'untitled'}.md`;
        downloadFile(filename, md);
      });
      toast('Blog files downloaded');
    }}, 'Download All Posts');

    wrap.appendChild(h('div', { className: 'flex gap-2' }, addBtn, dlBtn));
  }
  rebuild();
  return wrap;
}

// ─── 9. DEPLOY ─────────────────────────────────────────────────────────────────
function renderExport(): HTMLElement {
  const wrap = h('div', { className: 'max-w-2xl space-y-6' });

  // Save All card
  const saveCard = h('div', { className: cardCls });
  saveCard.appendChild(h('h3', { className: 'text-lg font-semibold text-white mb-2' }, 'Save All Changes'));
  saveCard.appendChild(h('p', { className: 'text-sm text-slate-400 mb-4' }, 'Save all configuration data to JSON files. Changes take effect after rebuild.'));
  const saveAllBtn = h('button', { className: 'flex items-center gap-2 px-6 py-3 bg-green-600 text-white text-sm font-semibold rounded-lg hover:brightness-110 transition-all cursor-pointer w-full justify-center shadow-lg shadow-green-600/20', onClick: () => saveAllConfigs() });
  saveAllBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Save All Configurations';
  saveCard.appendChild(saveAllBtn);
  wrap.appendChild(saveCard);

  // Download translations (TS files — download only)
  const dlCard = h('div', { className: cardCls });
  dlCard.appendChild(h('h3', { className: 'text-lg font-semibold text-white mb-2' }, 'Download Translation Files'));
  dlCard.appendChild(h('p', { className: 'text-sm text-slate-400 mb-4' }, 'Translation files are TypeScript — download and replace them manually.'));
  const dlGrid = h('div', { className: 'grid grid-cols-2 gap-3' });

  const downloads: [string, () => string][] = [
    ['en.ts', () => generateTranslationTs('en')],
    ['fr.ts', () => generateTranslationTs('fr')],
    ['ar.ts', () => generateTranslationTs('ar')],
    ['manifest.json', generateManifestJson],
  ];

  downloads.forEach(([name, gen]) => {
    const btn = h('button', { className: 'flex items-center gap-2 px-4 py-3 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white hover:bg-slate-700 transition-colors cursor-pointer', onClick: () => downloadFile(name, gen()) });
    btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> ${name}`;
    dlGrid.appendChild(btn);
  });
  dlCard.append(dlGrid);
  wrap.appendChild(dlCard);

  // Deploy hook
  const deployCard = h('div', { className: cardCls });
  deployCard.appendChild(h('h3', { className: 'text-lg font-semibold text-white mb-2' }, 'Deploy'));
  deployCard.appendChild(h('p', { className: 'text-sm text-slate-400 mb-4' }, 'Trigger a rebuild on Vercel after saving changes.'));

  const hookUrl = localStorage.getItem('admin_deploy_hook') || '';
  const hookInput = textInput(hookUrl, v => localStorage.setItem('admin_deploy_hook', v), 'https://api.vercel.com/v1/integrations/deploy/...');
  deployCard.append(field('Vercel Deploy Hook URL', hookInput));

  const triggerBtn = h('button', { className: btnCls + ' mt-3 w-full flex items-center gap-2 justify-center', onClick: async () => {
    const url = localStorage.getItem('admin_deploy_hook');
    if (!url) { toast('Set a deploy hook URL first', 'error'); return; }
    try {
      const res = await fetch(url, { method: 'POST' });
      if (res.ok) toast('Rebuild triggered!', 'success');
      else toast(`Deploy failed: ${res.status}`, 'error');
    } catch (e) { toast('Deploy request failed', 'error'); }
  }});
  triggerBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg> Trigger Rebuild';
  deployCard.appendChild(triggerBtn);
  wrap.appendChild(deployCard);

  return wrap;
}

// ─── FILE GENERATORS ──────────────────────────────────────────────────────────

function toTsLiteral(val: any, indent = 2): string {
  const pad = ' '.repeat(indent);
  const pad2 = ' '.repeat(indent + 2);

  if (val === null) return 'null';
  if (val === undefined) return 'undefined';
  if (typeof val === 'string') return JSON.stringify(val);
  if (typeof val === 'number' || typeof val === 'boolean') return String(val);

  if (Array.isArray(val)) {
    if (val.length === 0) return '[]';
    const items = val.map(v => `${pad2}${toTsLiteral(v, indent + 2)},`).join('\n');
    return `[\n${items}\n${pad}]`;
  }

  if (typeof val === 'object') {
    const entries = Object.entries(val);
    if (entries.length === 0) return '{}';
    const lines = entries.map(([k, v]) => {
      const key = /^[a-zA-Z_$][a-zA-Z0-9_$]*$/.test(k) ? k : JSON.stringify(k);
      return `${pad2}${key}: ${toTsLiteral(v, indent + 2)},`;
    }).join('\n');
    return `{\n${lines}\n${pad}}`;
  }

  return String(val);
}

function generateSiteTs(): string {
  return `export const SITE = ${toTsLiteral(state.site)} as const;\n`;
}

function generatePlansTs(): string {
  let out = `export interface Plan {\n  id: string;\n  type: 'single' | 'multi';\n  /** i18n key for duration label e.g. 'plans.duration.1m' */\n  durationLabel: string;\n  durationMonths: number;\n  priceEUR: number;\n  originalPriceEUR?: number;\n  devicesCount?: number;\n  isBestValue?: boolean;\n  /** Extra badge text shown on card e.g. '+ 2 FREE App activations' */\n  badge?: string;\n  /** WhatsApp message key for the CTA */\n  waMessageKey: 'pricing' | 'trial';\n}\n\n`;
  out += `export const SINGLE_PLANS: Plan[] = ${toTsLiteral(state.singlePlans)};\n\n`;
  out += `export const MULTI_PLANS: Plan[] = ${toTsLiteral(state.multiPlans)};\n\n`;
  out += `/** Features shown on all plan cards (i18n keys) */\nexport const PLAN_FEATURES_BASE = ${toTsLiteral(state.planFeaturesBase)} as const;\n\n`;
  out += `/** Features inside the expandable "More details" section (i18n keys) */\nexport const PLAN_FEATURES_EXTRA = ${toTsLiteral(state.planFeaturesExtra)} as const;\n`;
  return out;
}

function generateWhatsAppTs(): string {
  let out = `export const WHATSAPP_CONFIG = ${toTsLiteral(state.whatsapp)} as const;\n\n`;
  out += `export type MessageKey = keyof typeof WHATSAPP_CONFIG.messages;\n\n`;
  out += `export function getWhatsAppUrl(key: MessageKey = 'default'): string {\n`;
  out += `  const msg = WHATSAPP_CONFIG.messages[key];\n`;
  out += `  return \`https://wa.me/\${WHATSAPP_CONFIG.number}?text=\${encodeURIComponent(msg)}\`;\n`;
  out += `}\n`;
  return out;
}

function generateCarouselTs(): string {
  let out = `export interface CarouselItem {\n  title: string;\n  /** Optional external poster image URL (e.g. TMDB). Falls back to gradient placeholder. */\n  posterUrl?: string;\n}\n\n`;
  out += `export const CAROUSEL_ITEMS: CarouselItem[] = ${toTsLiteral(state.carouselItems)};\n`;
  return out;
}

function generateResellerTs(): string {
  let out = `export interface ResellerPackage {\n  name: string;\n  credits: number;\n  price: number;\n  bestSeller?: boolean;\n}\n\n`;
  out += `export interface ResellerTier {\n  tier: string;\n  color: string;\n  darkBg: string;\n  packages: ResellerPackage[];\n}\n\n`;
  out += `export const RESELLER_TIERS: ResellerTier[] = ${toTsLiteral(state.resellerTiers)};\n\n`;
  out += `export const WHY_RESELL_FEATURES = ${toTsLiteral(state.whyResellFeatures)};\n`;
  return out;
}

function generateTranslationTs(lang: 'en' | 'fr' | 'ar'): string {
  const data = state.translations[lang];

  if (lang === 'en') {
    let out = `const en = ${toTsLiteral(data)};\n\n`;
    out += `export default en;\n\n`;
    out += `/**\n * Recursively replaces all string literal types with \`string\`,\n * allowing FR/AR translations to use different string values\n * while still matching the same structural type.\n */\n`;
    out += `type Stringify<T> = T extends string\n  ? string\n  : T extends readonly (infer U)[]\n  ? Stringify<U>[]\n  : T extends (infer U)[]\n  ? Stringify<U>[]\n  : T extends object\n  ? { [K in keyof T]: Stringify<T[K]> }\n  : T;\n\n`;
    out += `export type Translations = Stringify<typeof en>;\n`;
    return out;
  }

  let out = `import type { Translations } from './en';\n\n`;
  out += `const ${lang}: Translations = ${toTsLiteral(data)};\n\n`;
  out += `export default ${lang};\n`;
  return out;
}

function generateManifestJson(): string {
  return JSON.stringify({
    name: `${state.site.name} — ${state.site.tagline}`,
    short_name: state.site.name,
    description: `Premium IPTV streaming with 10,000+ channels in 4K quality`,
    start_url: '/en/',
    display: 'standalone',
    theme_color: '#3B82F6',
    background_color: '#0F172A',
    icons: [{ src: '/favicon.svg', sizes: 'any', type: 'image/svg+xml' }],
  }, null, 2);
}

function generateBlogMd(post: any): string {
  const fm: Record<string, any> = {
    title: post.title,
    description: post.description,
    pubDate: post.pubDate ? post.pubDate.split('T')[0] : new Date().toISOString().split('T')[0],
    author: post.author || 'Admin',
    tags: post.tags || [],
    lang: post.lang || 'en',
    draft: !!post.draft,
    canonicalSlug: post.canonicalSlug || 'untitled',
  };
  if (post.updatedDate) fm.updatedDate = post.updatedDate.split('T')[0];

  let yaml = '---\n';
  for (const [k, v] of Object.entries(fm)) {
    if (Array.isArray(v)) {
      yaml += `${k}: [${v.map((i: string) => `"${i}"`).join(', ')}]\n`;
    } else if (typeof v === 'string') {
      yaml += `${k}: ${JSON.stringify(v)}\n`;
    } else {
      yaml += `${k}: ${v}\n`;
    }
  }
  yaml += '---\n\n';
  return yaml + (post.body || '');
}

// ─── DOWNLOAD & SAVE HELPERS ──────────────────────────────────────────────────

function downloadFile(filename: string, content: string) {
  const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
  toast(`Downloaded: ${filename}`);
}

async function saveConfig(file: string, data: any): Promise<boolean> {
  try {
    const res = await fetch('/api/save-config', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file, data }),
    });
    const json = await res.json();
    if (json.ok) {
      toast(`Saved ${file}`, 'success');
      return true;
    } else {
      toast(`Error: ${json.error}`, 'error');
      return false;
    }
  } catch (e: any) {
    toast(`Network error: ${e.message}`, 'error');
    return false;
  }
}

async function uploadImage(file: File): Promise<string | null> {
  try {
    const form = new FormData();
    form.append('file', file);
    const res = await fetch('/api/upload', { method: 'POST', body: form });
    const json = await res.json();
    if (json.ok) {
      toast('Image uploaded', 'success');
      return json.path;
    } else {
      toast(`Upload error: ${json.error}`, 'error');
      return null;
    }
  } catch (e: any) {
    toast(`Upload failed: ${e.message}`, 'error');
    return null;
  }
}

async function saveAllConfigs() {
  const saves = [
    saveConfig('site.json', state.site),
    saveConfig('plans.json', {
      singlePlans: state.singlePlans,
      multiPlans: state.multiPlans,
      featuresBase: state.planFeaturesBase,
      featuresExtra: state.planFeaturesExtra,
    }),
    saveConfig('whatsapp.json', state.whatsapp),
    saveConfig('carousel.json', state.carouselItems),
    saveConfig('reseller.json', {
      tiers: state.resellerTiers,
      whyResellFeatures: state.whyResellFeatures,
    }),
  ];
  const results = await Promise.all(saves);
  if (results.every(Boolean)) {
    toast('All configs saved! Rebuild to apply.', 'success');
  } else {
    toast('Some saves failed — check errors above', 'error');
  }
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
if (isAuthenticated()) {
  renderAdmin();
} else {
  renderLogin();
}

})();
</script>

