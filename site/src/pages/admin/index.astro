---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { SITE } from '../../config/site';
import { SINGLE_PLANS, MULTI_PLANS, PLAN_FEATURES_BASE, PLAN_FEATURES_EXTRA } from '../../config/plans';
import { WHATSAPP_CONFIG } from '../../config/whatsapp';
import { RESELLER_TIERS, WHY_RESELL_FEATURES } from '../../config/reseller';
import { CAROUSEL_ITEMS } from '../../config/carousel';
import en from '../../i18n/en';
import fr from '../../i18n/fr';
import ar from '../../i18n/ar';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const serializedPosts = blogPosts.map((p: any) => ({
  slug: p.slug,
  body: p.body,
  ...p.data,
  pubDate: p.data.pubDate?.toISOString?.() ?? p.data.pubDate,
  updatedDate: p.data.updatedDate?.toISOString?.() ?? p.data.updatedDate ?? null,
}));

const adminData = {
  site: SITE,
  singlePlans: SINGLE_PLANS,
  multiPlans: MULTI_PLANS,
  planFeaturesBase: PLAN_FEATURES_BASE,
  planFeaturesExtra: PLAN_FEATURES_EXTRA,
  whatsapp: WHATSAPP_CONFIG,
  resellerTiers: RESELLER_TIERS,
  whyResellFeatures: WHY_RESELL_FEATURES,
  translations: { en, fr, ar },
  blogPosts: serializedPosts,
  carouselItems: CAROUSEL_ITEMS,
};

// SHA-256 hash of "limitless2024" computed at build time
import { createHash } from 'node:crypto';
const passwordHash = createHash('sha256').update('limitless2024').digest('hex');
---

<Base lang="en" title="Admin Panel" description="Site administration panel" noIndex={true}>

<div id="admin-root"></div>

<script id="admin-data" type="application/json" set:html={JSON.stringify(adminData)} />
<script id="admin-password-hash" type="application/json" set:html={JSON.stringify(passwordHash)} />

<script>
// ─── Admin Panel SPA ──────────────────────────────────────────────────────────
(function AdminPanel() {

// ─── DATA ──────────────────────────────────────────────────────────────────────
const DATA = JSON.parse(document.getElementById('admin-data')!.textContent!);
const PASS_HASH = JSON.parse(document.getElementById('admin-password-hash')!.textContent!);

// Deep clone helper
function clone<T>(obj: T): T { return JSON.parse(JSON.stringify(obj)); }

// Mutable state
let state = {
  site: clone(DATA.site),
  singlePlans: clone(DATA.singlePlans),
  multiPlans: clone(DATA.multiPlans),
  planFeaturesBase: clone(DATA.planFeaturesBase),
  planFeaturesExtra: clone(DATA.planFeaturesExtra),
  whatsapp: clone(DATA.whatsapp),
  resellerTiers: clone(DATA.resellerTiers),
  whyResellFeatures: clone(DATA.whyResellFeatures),
  translations: clone(DATA.translations),
  blogPosts: clone(DATA.blogPosts),
  carouselItems: clone(DATA.carouselItems),
};

// ─── AUTH ──────────────────────────────────────────────────────────────────────
async function sha256(text: string): Promise<string> {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
}

function isAuthenticated(): boolean {
  return sessionStorage.getItem('admin_auth') === 'true';
}

// ─── TOAST ─────────────────────────────────────────────────────────────────────
function toast(msg: string, type: 'success' | 'error' | 'info' = 'success') {
  const el = document.createElement('div');
  const colors = { success: 'bg-green-600', error: 'bg-red-600', info: 'bg-blue-600' };
  el.className = `fixed top-4 right-4 z-[9999] px-5 py-3 rounded-lg text-white text-sm font-medium shadow-xl ${colors[type]} transition-all duration-300 opacity-0 translate-y-[-10px]`;
  el.textContent = msg;
  document.body.appendChild(el);
  requestAnimationFrame(() => { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; });
  setTimeout(() => {
    el.style.opacity = '0'; el.style.transform = 'translateY(-10px)';
    setTimeout(() => el.remove(), 300);
  }, 3000);
}

// ─── HELPERS ───────────────────────────────────────────────────────────────────
function h(tag: string, attrs: Record<string, any> = {}, ...children: (string | Node | null)[]): HTMLElement {
  const el = document.createElement(tag);
  for (const [k, v] of Object.entries(attrs)) {
    if (k === 'className') el.className = v;
    else if (k.startsWith('on') && typeof v === 'function') el.addEventListener(k.slice(2).toLowerCase(), v);
    else if (k === 'value' && (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) (el as any).value = v;
    else if (k === 'checked' && el instanceof HTMLInputElement) el.checked = v;
    else if (k === 'selected' && el instanceof HTMLOptionElement) el.selected = v;
    else if (k === 'htmlFor') (el as HTMLLabelElement).htmlFor = v;
    else if (k === 'type') (el as HTMLInputElement).type = v;
    else el.setAttribute(k, String(v));
  }
  for (const c of children) {
    if (c === null) continue;
    el.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
  }
  return el;
}

function getNestedValue(obj: any, path: string): any {
  return path.split('.').reduce((o, k) => o?.[k], obj);
}

function setNestedValue(obj: any, path: string, value: any): void {
  const keys = path.split('.');
  const last = keys.pop()!;
  let cur = obj;
  for (const k of keys) { if (!cur[k]) cur[k] = {}; cur = cur[k]; }
  cur[last] = value;
}

// ─── FORM COMPONENTS ──────────────────────────────────────────────────────────
const inputCls = 'w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500';
const textareaCls = inputCls + ' min-h-[80px] resize-y';
const labelCls = 'block text-sm font-medium text-slate-300 mb-1';
const btnCls = 'px-4 py-2 bg-[#3B82F6] text-white text-sm font-medium rounded-lg hover:brightness-110 transition-all cursor-pointer';
const btnDangerCls = 'px-3 py-1.5 bg-red-600 text-white text-xs font-medium rounded-lg hover:brightness-110 transition-all cursor-pointer';
const btnSmCls = 'px-3 py-1.5 bg-[#3B82F6] text-white text-xs font-medium rounded-lg hover:brightness-110 transition-all cursor-pointer';
const cardCls = 'bg-slate-800/50 border border-slate-700 rounded-xl p-5 space-y-4';

function field(label: string, inputEl: HTMLElement): HTMLElement {
  return h('div', { className: 'space-y-1' }, h('label', { className: labelCls }, label), inputEl);
}

function textInput(value: string, onChange: (v: string) => void, placeholder = ''): HTMLInputElement {
  const inp = h('input', { type: 'text', className: inputCls, value, placeholder }) as HTMLInputElement;
  inp.addEventListener('input', () => onChange(inp.value));
  return inp;
}

function numberInput(value: number, onChange: (v: number) => void): HTMLInputElement {
  const inp = h('input', { type: 'number', className: inputCls, value: String(value) }) as HTMLInputElement;
  inp.addEventListener('input', () => onChange(Number(inp.value)));
  return inp;
}

function textareaInput(value: string, onChange: (v: string) => void, rows = 3): HTMLTextAreaElement {
  const ta = h('textarea', { className: textareaCls, rows: String(rows) }) as HTMLTextAreaElement;
  ta.value = value;
  ta.addEventListener('input', () => onChange(ta.value));
  return ta;
}

function selectInput(options: {value: string; label: string}[], selected: string, onChange: (v: string) => void): HTMLSelectElement {
  const sel = h('select', { className: inputCls }) as HTMLSelectElement;
  for (const opt of options) {
    const o = h('option', { value: opt.value }, opt.label) as HTMLOptionElement;
    if (opt.value === selected) o.selected = true;
    sel.appendChild(o);
  }
  sel.addEventListener('change', () => onChange(sel.value));
  return sel;
}

function toggleSwitch(value: boolean, onChange: (v: boolean) => void): HTMLElement {
  const wrapper = h('div', { className: 'relative inline-flex items-center cursor-pointer' });
  const inp = h('input', { type: 'checkbox', className: 'sr-only' }) as HTMLInputElement;
  inp.checked = value;
  const dot = h('span', { className: `absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full transition-transform ${value ? 'translate-x-6' : ''}` });
  const track = h('span', { className: `block w-12 h-6 rounded-full transition-colors ${value ? 'bg-blue-500' : 'bg-slate-600'}` });
  wrapper.append(inp, track, dot);
  wrapper.addEventListener('click', () => {
    inp.checked = !inp.checked;
    const v = inp.checked;
    dot.className = `absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full transition-transform ${v ? 'translate-x-6' : ''}`;
    track.className = `block w-12 h-6 rounded-full transition-colors ${v ? 'bg-blue-500' : 'bg-slate-600'}`;
    onChange(v);
  });
  return wrapper;
}

function tabs(labels: string[], activeIdx: number, onSwitch: (i: number) => void): HTMLElement {
  const bar = h('div', { className: 'flex gap-1 bg-slate-800 rounded-lg p-1 mb-4' });
  labels.forEach((lbl, i) => {
    const cls = i === activeIdx
      ? 'flex-1 px-3 py-2 text-sm font-medium rounded-md bg-[#3B82F6] text-white text-center cursor-pointer'
      : 'flex-1 px-3 py-2 text-sm font-medium rounded-md text-slate-400 hover:text-white text-center cursor-pointer';
    bar.appendChild(h('button', { className: cls, onClick: () => onSwitch(i) }, lbl));
  });
  return bar;
}

// ─── SECTIONS ──────────────────────────────────────────────────────────────────
type SectionKey = 'site' | 'plans' | 'whatsapp' | 'testimonials' | 'faq' | 'carousel' | 'translations' | 'reseller' | 'blog' | 'export';

const SECTIONS: { key: SectionKey; label: string; icon: string }[] = [
  { key: 'site', label: 'Site Settings', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>' },
  { key: 'plans', label: 'Pricing Plans', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' },
  { key: 'whatsapp', label: 'Contact', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>' },
  { key: 'testimonials', label: 'Testimonials', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>' },
  { key: 'faq', label: 'FAQ', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' },
  { key: 'carousel', label: 'Movie Carousel', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>' },
  { key: 'translations', label: 'Translations', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>' },
  { key: 'reseller', label: 'Reseller', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>' },
  { key: 'blog', label: 'Blog', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>' },
  { key: 'export', label: 'Deploy', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>' },
];

let activeSection: SectionKey = 'site';
let mobileMenuOpen = false;

// ─── RENDER LOGIN ──────────────────────────────────────────────────────────────
function renderLogin() {
  const root = document.getElementById('admin-root')!;
  root.innerHTML = '';

  const wrapper = h('div', { className: 'min-h-screen bg-slate-950 flex items-center justify-center p-4' });
  const card = h('div', { className: 'w-full max-w-sm bg-slate-900 rounded-2xl p-8 shadow-2xl border border-slate-800' });

  const title = h('h1', { className: 'text-2xl font-bold text-white text-center mb-2' }, 'Admin Panel');
  const subtitle = h('p', { className: 'text-slate-400 text-sm text-center mb-6' }, 'Enter your password to continue');

  const passInput = h('input', { type: 'password', className: inputCls + ' mb-4', placeholder: 'Password' }) as HTMLInputElement;
  const errorMsg = h('p', { className: 'text-red-400 text-sm mb-3 hidden' }, 'Invalid password');
  const loginBtn = h('button', { className: btnCls + ' w-full' }, 'Sign In');

  async function tryLogin() {
    const hash = await sha256(passInput.value);
    if (hash === PASS_HASH) {
      sessionStorage.setItem('admin_auth', 'true');
      renderAdmin();
    } else {
      errorMsg.classList.remove('hidden');
      passInput.classList.add('border-red-500');
    }
  }

  loginBtn.addEventListener('click', tryLogin);
  passInput.addEventListener('keydown', (e: Event) => { if ((e as KeyboardEvent).key === 'Enter') tryLogin(); });

  card.append(title, subtitle, passInput, errorMsg, loginBtn);
  wrapper.appendChild(card);
  root.appendChild(wrapper);
  passInput.focus();
}

// ─── RENDER ADMIN SHELL ────────────────────────────────────────────────────────
function renderAdmin() {
  const root = document.getElementById('admin-root')!;
  root.innerHTML = '';
  root.className = 'min-h-screen bg-slate-950 text-white';

  // Mobile menu toggle
  const mobileToggle = h('button', {
    className: 'lg:hidden fixed top-4 left-4 z-50 p-2 bg-slate-800 rounded-lg border border-slate-700',
    onClick: () => { mobileMenuOpen = !mobileMenuOpen; updateMobileMenu(); }
  });
  mobileToggle.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>';

  // Sidebar
  const sidebar = h('aside', { id: 'admin-sidebar', className: 'fixed left-0 top-0 bottom-0 w-64 bg-slate-900 border-r border-slate-800 z-40 flex flex-col hidden lg:flex' });
  const sidebarHeader = h('div', { className: 'p-5 border-b border-slate-800' },
    h('h2', { className: 'text-lg font-bold text-white' }, 'Admin Panel'),
    h('p', { className: 'text-xs text-slate-500 mt-1' }, 'Content Management')
  );
  const nav = h('nav', { className: 'flex-1 overflow-y-auto p-3 space-y-1' });

  SECTIONS.forEach(sec => {
    const isActive = sec.key === activeSection;
    const btn = h('button', {
      className: `w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${isActive ? 'bg-[#3B82F6]/10 text-[#3B82F6]' : 'text-slate-400 hover:text-white hover:bg-slate-800'}`,
      onClick: () => { activeSection = sec.key; mobileMenuOpen = false; renderAdmin(); }
    });
    const iconSpan = h('span', {});
    iconSpan.innerHTML = sec.icon;
    btn.append(iconSpan, document.createTextNode(sec.label));
    nav.appendChild(btn);
  });

  const logoutBtn = h('div', { className: 'p-3 border-t border-slate-800' },
    h('button', {
      className: 'w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-red-400 hover:bg-red-500/10 transition-colors',
      onClick: () => { sessionStorage.removeItem('admin_auth'); renderLogin(); }
    }, 'Sign Out')
  );

  sidebar.append(sidebarHeader, nav, logoutBtn);

  // Main content
  const main = h('main', { className: 'lg:ml-64 min-h-screen' });

  // Top bar
  const topBar = h('div', { className: 'sticky top-0 z-30 bg-slate-950/80 backdrop-blur-lg border-b border-slate-800 px-6 py-4 flex items-center justify-between' });
  const topTitle = h('h1', { className: 'text-xl font-bold pl-10 lg:pl-0' }, SECTIONS.find(s => s.key === activeSection)!.label);
  const downloadAllBtn = h('button', {
    className: 'flex items-center gap-2 px-5 py-2.5 bg-green-600 text-white text-sm font-semibold rounded-lg hover:brightness-110 transition-all cursor-pointer shadow-lg shadow-green-600/20',
    onClick: () => saveAllConfigs()
  });
  downloadAllBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Save All';
  topBar.append(topTitle, downloadAllBtn);

  // Content area
  const content = h('div', { className: 'p-6' });
  renderSection(content, activeSection);

  main.append(topBar, content);
  root.append(mobileToggle, sidebar, main);

  function updateMobileMenu() {
    sidebar.className = `fixed left-0 top-0 bottom-0 w-64 bg-slate-900 border-r border-slate-800 z-40 flex flex-col transition-transform duration-300 ${mobileMenuOpen ? 'translate-x-0' : '-translate-x-full'} lg:translate-x-0`;
  }
  updateMobileMenu();
}

// ─── SECTION ROUTER ────────────────────────────────────────────────────────────
function renderSection(container: HTMLElement, key: SectionKey) {
  const renderers: Record<SectionKey, () => HTMLElement> = {
    site: renderSiteSettings,
    plans: renderPlans,
    whatsapp: renderWhatsApp,
    testimonials: renderTestimonials,
    faq: renderFAQ,
    carousel: renderCarousel,
    translations: renderTranslations,
    reseller: renderReseller,
    blog: renderBlog,
    export: renderExport,
  };
  container.appendChild(renderers[key]());
}

// ─── 1. SITE SETTINGS ─────────────────────────────────────────────────────────
function renderSiteSettings(): HTMLElement {
  const s = state.site;
  const wrap = h('div', { className: 'max-w-2xl space-y-6' });
  const card = h('div', { className: cardCls });

  const fields: [string, string, 'text' | 'number', string][] = [
    ['Name', 'name', 'text', s.name],
    ['Tagline', 'tagline', 'text', s.tagline],
    ['Domain', 'domain', 'text', s.domain],
    ['URL', 'url', 'text', s.url],
    ['Email', 'email', 'text', s.email],
    ['Founded Year', 'foundedYear', 'number', String(s.foundedYear)],
    ['Support Hours Open', 'supportHours.open', 'number', String(s.supportHours.open)],
    ['Support Hours Close', 'supportHours.close', 'number', String(s.supportHours.close)],
    ['Currency', 'currency', 'text', s.currency],
    ['Currency Symbol', 'currencySymbol', 'text', s.currencySymbol],
    ['Telegram URL', 'socialLinks.telegram', 'text', s.socialLinks.telegram],
    ['GA4 ID', 'ga4Id', 'text', s.ga4Id],
  ];

  const grid = h('div', { className: 'grid grid-cols-1 md:grid-cols-2 gap-4' });
  fields.forEach(([label, path, type, val]) => {
    if (type === 'number') {
      grid.appendChild(field(label, numberInput(Number(val), v => setNestedValue(state.site, path, v))));
    } else {
      grid.appendChild(field(label, textInput(val, v => setNestedValue(state.site, path, v))));
    }
  });

  const saveBtn = h('button', { className: 'flex items-center gap-2 px-5 py-2.5 bg-green-600 text-white text-sm font-semibold rounded-lg hover:brightness-110 transition-all cursor-pointer', onClick: () => {
    saveConfig('site.json', state.site);
  }});
