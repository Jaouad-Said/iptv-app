---
import { SITE } from '../../config/site';
import { FOOTER_LINKS } from '../../config/navigation';
import { useTranslations, interpolate } from '../../i18n/index';
import { getWhatsAppUrl } from '../../config/whatsapp';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const waUrl = getWhatsAppUrl('default');

function navHref(href: string) {
  if (href.startsWith('#')) return href;
  return href ? `/${lang}/${href}` : `/${lang}/`;
}

const year = new Date().getFullYear();
const copyright = interpolate(t('footer').copyright, { year, brand: SITE.name });
---

<footer class="bg-white dark:bg-slate-950 border-t border-slate-200/70 dark:border-slate-800">
  <!-- Top CTA strip -->
  <div class="bg-[#3B82F6]/5 border-b border-[#3B82F6]/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <p class="font-semibold text-slate-800 dark:text-slate-100">{t('contact').title}</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">{t('contact').hours}</p>
      </div>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#25D366] text-white text-sm font-semibold
               hover:brightness-110 transition-all duration-150 shadow-md shrink-0"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {t('contact').cta_whatsapp}
      </a>
    </div>
  </div>

  <!-- Main footer links -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="col-span-2 sm:col-span-1">
        <a href={`/${lang}/`} class="text-xl font-extrabold text-[#3B82F6]">{SITE.name}</a>
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-400 leading-relaxed max-w-xs">
          {t('footer').tagline}
        </p>
        {SITE.socialLinks.telegram && (
          <a
            href={SITE.socialLinks.telegram}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 mt-4 text-sm text-slate-500 dark:text-slate-400
                   hover:text-[#3B82F6] transition-colors duration-150"
            aria-label="Telegram"
          >
            <!-- Telegram icon -->
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
            Telegram
          </a>
        )}
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold text-slate-800 dark:text-slate-100 mb-3">{t('footer').services}</h3>
        <ul class="space-y-2">
          {FOOTER_LINKS.services.map(link => (
            <li>
              <a
                href={navHref(link.href)}
                class="text-sm text-slate-500 dark:text-slate-400 hover:text-[#3B82F6] transition-colors duration-150"
              >
                {t(link.key as any)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Help -->
      <div>
        <h3 class="text-sm font-semibold text-slate-800 dark:text-slate-100 mb-3">{t('footer').help}</h3>
        <ul class="space-y-2">
          {FOOTER_LINKS.help.map(link => (
            <li>
              <a
                href={navHref(link.href)}
                class="text-sm text-slate-500 dark:text-slate-400 hover:text-[#3B82F6] transition-colors duration-150"
              >
                {t(link.key as any)}
              </a>
            </li>
          ))}
          <li>
            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 dark:text-slate-400 hover:text-[#3B82F6] transition-colors duration-150"
            >
              WhatsApp
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-slate-800 dark:text-slate-100 mb-3">{t('footer').legal}</h3>
        <ul class="space-y-2">
          {FOOTER_LINKS.legal.map(link => (
            <li>
              <a
                href={navHref(link.href)}
                class="text-sm text-slate-500 dark:text-slate-400 hover:text-[#3B82F6] transition-colors duration-150"
              >
                {t(link.key as any)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-200/70 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-slate-400 dark:text-slate-500">{copyright}</p>
      <p class="text-xs text-slate-400 dark:text-slate-500">{SITE.email}</p>
    </div>
  </div>
</footer>
