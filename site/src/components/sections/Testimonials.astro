---
import { useTranslations } from '../../i18n/index';
import type { Locale } from '../../config/locales';
import { SITE } from '../../config/site';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const testimonialsT = t('testimonials');
---

<section
  class="relative py-24 px-4 sm:px-6 overflow-hidden"
  aria-labelledby="testimonials-title"
>
  <!-- Mesh gradient background -->
  <div class="absolute inset-0 mesh-gradient pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16" data-reveal>
      <h2
        id="testimonials-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold"
      >
        <span class="text-gradient">{testimonialsT.title}</span>
      </h2>
      <p class="mt-4 text-slate-500 dark:text-slate-400 text-lg max-w-2xl mx-auto">
        {testimonialsT.subtitle}
      </p>
    </div>

    <!-- Testimonial cards — horizontal row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonialsT.reviews.map((testimonial, i) => (
        <div
          class="glass-card rounded-2xl p-7 sm:p-8 relative flex flex-col border-t-2 border-t-[#3B82F6]/40"
          data-reveal
          style={`transition-delay: ${i * 120}ms`}
        >
          <!-- Star rating -->
          <div class="flex gap-1 mb-5" aria-label={`${testimonial.stars} out of 5 stars`}>
            {Array.from({ length: Number(testimonial.stars) }).map(() => (
              <svg class="w-5 h-5 text-[#F59E0B]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="flex-1 mb-6">
            <p class="text-slate-700 dark:text-slate-200 text-base leading-relaxed italic">
              &ldquo;{testimonial.quote}&rdquo;
            </p>
          </blockquote>

          <!-- Author info -->
          <div class="flex items-center gap-3 pt-5 border-t border-slate-200/50 dark:border-slate-700/50">
            <!-- Avatar circle with initials -->
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#3B82F6] to-[#F59E0B] flex items-center justify-center text-white font-bold text-sm shrink-0">
              {testimonial.author.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-slate-800 dark:text-slate-100 text-sm">
                {testimonial.author}
              </p>
              <p class="text-xs text-slate-500 dark:text-slate-400 flex items-center gap-1.5">
                <span aria-label={testimonial.country}>{testimonial.flag}</span>
                {testimonial.country}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": SITE.name,
    "description": "Premium IPTV streaming service",
    "brand": { "@type": "Brand", "name": SITE.name },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "ratingCount": String(testimonialsT.reviews.length),
      "reviewCount": String(testimonialsT.reviews.length)
    },
    "review": testimonialsT.reviews.map(r => ({
      "@type": "Review",
      "author": { "@type": "Person", "name": r.author },
      "reviewRating": { "@type": "Rating", "ratingValue": String(r.stars), "bestRating": "5" },
      "reviewBody": r.quote
    }))
  })} />
</section>
