---
import { SITE } from '../../config/site';
import { useTranslations, interpolate } from '../../i18n/index';
import { getWhatsAppUrl } from '../../config/whatsapp';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const howItWorks = t('howItWorks');
const title = interpolate(howItWorks.title, { brand: SITE.name });
const waUrl = getWhatsAppUrl('trial');

/* Split title so the brand name gets the gradient treatment */
const brandName = SITE.name;
const titleBeforeBrand = title.split(brandName)[0] ?? '';
const titleAfterBrand = title.split(brandName)[1] ?? '';
---

<section
  class="py-24 px-4 bg-white dark:bg-slate-950 overflow-hidden"
  aria-labelledby="how-it-works-title"
>
  <div class="max-w-6xl mx-auto">
    <!-- Section heading -->
    <div class="text-center mb-20" data-reveal>
      <h2
        id="how-it-works-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-800 dark:text-slate-100"
      >
        {titleBeforeBrand}<span class="text-gradient">{brandName}</span>{titleAfterBrand}
      </h2>
    </div>

    <!-- Horizontal timeline (desktop) / Vertical timeline (mobile) -->
    <div class="relative">
      <!-- Horizontal dotted connector (lg+) -->
      <div
        class="hidden lg:block absolute top-10 start-[calc(16.66%+28px)] end-[calc(16.66%+28px)] border-t-2 border-dashed border-[#3B82F6]/40"
        aria-hidden="true"
      ></div>

      <!-- Vertical dotted connector (mobile/tablet) -->
      <div
        class="lg:hidden absolute top-10 bottom-10 start-[27px] w-0 border-s-2 border-dashed border-[#3B82F6]/30"
        aria-hidden="true"
      ></div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {howItWorks.steps.map((step, i) => (
          <div
            class="relative flex flex-row lg:flex-col items-start lg:items-center gap-5 lg:gap-0 lg:text-center"
            data-reveal
            style={`transition-delay: ${i * 150}ms`}
          >
            {/* Step circle with glow on first */}
            <div
              class:list={[
                'relative z-10 flex items-center justify-center w-14 h-14 rounded-full shrink-0',
                'bg-slate-950 dark:bg-slate-800 border-2 border-[#3B82F6] text-[#3B82F6]',
                'text-base font-extrabold tracking-wider lg:mb-8',
                i === 0 && 'animate-glow',
              ]}
            >
              {step.number}
            </div>

            {/* Content */}
            <div class="flex-1 lg:flex-none">
              <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100 mb-2">
                {step.title}
              </h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed max-w-xs lg:mx-auto">
                {step.description}
              </p>

              {step.cta && (
                <a
                  href={waUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                         bg-[#3B82F6]/10 text-[#3B82F6] text-sm font-semibold
                         border border-[#3B82F6]/30
                         hover:bg-[#3B82F6] hover:text-white
                         transition-all duration-200"
                >
                  <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                  </svg>
                  {step.cta}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.setAttribute('data-visible', '');
      }),
    { threshold: 0.15 }
  );
  document
    .querySelectorAll('#how-it-works-title, [data-reveal]')
    .forEach((el) => observer.observe(el));
</script>
