---
import { SITE } from '../../config/site';
import { getWhatsAppUrl } from '../../config/whatsapp';
import { useTranslations } from '../../i18n/index';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const hero = t('hero');
const waUrl = getWhatsAppUrl('trial');
const pricingUrl = `/${lang}/pricing`;

/* Split the headline on {brand} to wrap brand in a gradient span */
const headlineParts = hero.headline.split('{brand}');
---

<!-- Hero: split layout — text LEFT, illustration RIGHT -->
<section
  class="relative min-h-screen flex items-center overflow-hidden
         bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950"
  aria-label="Hero"
>
  <!-- Mesh gradient overlay -->
  <div class="absolute inset-0 mesh-gradient pointer-events-none" aria-hidden="true"></div>

  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Large green glow — positioned behind the device illustration -->
    <div class="absolute top-1/3 right-[10%] w-[500px] h-[500px] rounded-full
                bg-[#3B82F6]/8 blur-[140px]"></div>
    <!-- Indigo accent glow — top left -->
    <div class="absolute -top-20 -left-20 w-[350px] h-[350px] rounded-full
                bg-[#F59E0B]/6 blur-[100px]"></div>

    <!-- Decorative dots -->
    <div class="absolute top-[15%] left-[8%] w-2 h-2 rounded-full bg-[#3B82F6]/40"></div>
    <div class="absolute top-[25%] left-[12%] w-1.5 h-1.5 rounded-full bg-[#F59E0B]/30"></div>
    <div class="absolute top-[60%] left-[5%] w-1 h-1 rounded-full bg-[#3B82F6]/25"></div>
    <div class="absolute top-[20%] right-[15%] w-2.5 h-2.5 rounded-full bg-[#3B82F6]/20"></div>
    <div class="absolute bottom-[30%] right-[8%] w-1.5 h-1.5 rounded-full bg-[#F59E0B]/25"></div>

    <!-- Decorative circles (outlines) -->
    <div class="absolute top-[10%] right-[25%] w-16 h-16 rounded-full border border-[#3B82F6]/10"></div>
    <div class="absolute bottom-[25%] left-[15%] w-24 h-24 rounded-full border border-[#F59E0B]/8"></div>
    <div class="absolute top-[45%] left-[3%] w-10 h-10 rounded-full border border-white/5"></div>
  </div>

  <!-- Main content grid: split layout -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 py-24 lg:py-0">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-8 items-center">

      <!-- LEFT — Text content (60%) -->
      <div class="lg:col-span-3 text-center lg:text-start" data-reveal-left>
        <!-- Badge pill -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#3B82F6]/30
                    bg-[#3B82F6]/10 text-[#3B82F6] text-xs font-semibold uppercase tracking-wider mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-[#3B82F6] animate-pulse"></span>
          Premium IPTV Service
        </div>

        <!-- Headline -->
        <h1 class="text-2xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-[1.1] tracking-tight mb-6">
          {headlineParts[0]}<span class="text-gradient">{SITE.name}</span>{headlineParts[1] ?? ''}
        </h1>

        <!-- Subheadline -->
        <p class="text-lg sm:text-xl text-slate-300 max-w-sm sm:max-w-md md:max-w-xl mx-auto lg:mx-0 leading-relaxed mb-10">
          {hero.subheadline}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4">
          <!-- WhatsApp green pill -->
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-2.5 px-7 py-4 rounded-full bg-[#25D366] text-white
                   font-semibold text-base hover:brightness-110 hover:scale-[1.03]
                   transition-all duration-200 shadow-lg shadow-[#25D366]/25
                   w-full sm:w-auto justify-center"
          >
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            {hero.cta_primary}
          </a>

          <!-- Outline pill for pricing -->
          <a
            href={pricingUrl}
            class="group flex items-center gap-2 px-7 py-4 rounded-full border border-white/20
                   text-white font-semibold text-base hover:bg-white/10 hover:border-white/30
                   transition-all duration-200 w-full sm:w-auto justify-center"
          >
            {hero.cta_secondary}
            <svg class="w-4 h-4 rtl:rotate-180 shrink-0 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Trust badges row -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-x-3 sm:gap-x-6 gap-y-3 mt-12 text-slate-400 text-sm">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#3B82F6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Instant Activation
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#3B82F6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            4K Ultra HD
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#3B82F6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            7-Day Money Back
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#3B82F6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Human Support
          </span>
        </div>
      </div>

      <!-- RIGHT — Floating device illustration (40%) -->
      <div class="lg:col-span-2 flex items-center justify-center relative" data-reveal-right>
        <!-- Green glow circle behind illustration -->
        <div class="absolute w-[80%] aspect-square rounded-full bg-[#3B82F6]/10 blur-[80px] animate-glow" aria-hidden="true"></div>
        <!-- Secondary glow ring -->
        <div class="absolute w-[60%] aspect-square rounded-full border border-[#3B82F6]/15" aria-hidden="true"></div>

        <!-- Device SVG with floating animation -->
        <img
          src="/assets/images/hero-devices.svg"
          alt="Stream on any device — Smart TV, tablet, phone, and laptop"
          class="relative z-10 w-full max-w-md lg:max-w-lg xl:max-w-xl animate-float drop-shadow-2xl"
          width="600"
          height="450"
          loading="eager"
        />
      </div>

    </div>
  </div>

  <!-- Wave divider at very bottom -->
  <div class="absolute -bottom-1 left-0 right-0 z-20 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16 sm:h-20">
      <path d="M0,64 C360,0 720,80 1080,32 C1260,8 1380,48 1440,40 L1440,80 L0,80 Z" fill="currentColor" class="text-slate-950"/>
    </svg>
  </div>

  <!-- Ticker strip above wave -->
  <div class="absolute bottom-14 sm:bottom-16 start-0 end-0 overflow-hidden py-3
              border-t border-b border-white/10 bg-black/60 backdrop-blur-md z-30">
    <div class="ticker-track flex whitespace-nowrap gap-6 sm:gap-10 text-white text-sm sm:text-base font-medium">
      {[...hero.ticker, ...hero.ticker].map(item => (
        <span class="flex items-center gap-2.5 shrink-0">
          <span class="w-1.5 h-1.5 rounded-full bg-[#3B82F6] animate-pulse" aria-hidden="true"></span>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
