---
import { useTranslations } from '../../i18n/index';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
  /** If true, shows the section title (useful for standalone FAQ page) */
  showTitle?: boolean;
}

const { lang, showTitle = true } = Astro.props;
const t = useTranslations(lang);
const faq = t('faq');
---

<section
  class="py-20 px-4 bg-white dark:bg-slate-950"
  aria-labelledby="faq-title"
>
  <div class="max-w-3xl mx-auto">
    {showTitle && (
      <div class="text-center mb-12" data-reveal>
        <h2 id="faq-title" class="text-3xl sm:text-4xl font-extrabold text-slate-800 dark:text-slate-100">
          {faq.title}
        </h2>
      </div>
    )}

    <!-- JSON-LD FAQPage schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.items.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    })} />

    <div class="space-y-3">
      {faq.items.map((item) => (
        <details
          class="group border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden
                 open:border-[#3B82F6]/30 transition-colors duration-150"
          data-reveal
        >
          <summary
            class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer
                   text-slate-800 dark:text-slate-100 font-medium text-sm sm:text-base
                   hover:bg-slate-50 dark:hover:bg-slate-900/50 transition-colors duration-100
                   list-none"
          >
            <span>{item.q}</span>
            <!-- Chevron arrow -->
            <svg
              class="w-4 h-4 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1 text-sm text-slate-500 dark:text-slate-400 leading-relaxed border-t border-slate-100 dark:border-slate-800">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
