---
import { SITE } from '../../config/site';
import { useTranslations } from '../../i18n/index';
import { getWhatsAppUrl } from '../../config/whatsapp';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const contact = t('contact');
const waUrl = getWhatsAppUrl('default');

/* Determine if currently within support hours (rough CET) */
const now = new Date();
const hour = now.getUTCHours() + 1;
const isOpen = hour >= SITE.supportHours.open && hour < SITE.supportHours.close;
---

<section
  id="contact"
  class="relative py-14 sm:py-18 md:py-24 px-4 overflow-hidden"
  aria-labelledby="contact-title"
>
  {/* Diagonal gradient background */}
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#3B82F6] via-[#2563EB] to-[#1E40AF]"
    aria-hidden="true"
  ></div>

  {/* Subtle dark overlay for depth */}
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"
    aria-hidden="true"
  ></div>

  {/* Decorative floating dots */}
  <div class="absolute top-12 start-[8%] w-2 h-2 rounded-full bg-white/20 animate-float" aria-hidden="true"></div>
  <div class="absolute top-1/3 end-[12%] w-3 h-3 rounded-full bg-white/15 animate-float-slow" aria-hidden="true"></div>
  <div class="absolute bottom-16 start-[15%] w-2.5 h-2.5 rounded-full bg-white/10 animate-float" aria-hidden="true" style="animation-delay: 1s;"></div>
  <div class="absolute top-1/4 start-[45%] w-1.5 h-1.5 rounded-full bg-white/20 animate-float-slow" aria-hidden="true" style="animation-delay: 0.5s;"></div>
  <div class="absolute bottom-1/4 end-[20%] w-2 h-2 rounded-full bg-white/15 animate-float" aria-hidden="true" style="animation-delay: 2s;"></div>
  <div class="absolute top-16 end-[30%] w-1.5 h-1.5 rounded-full bg-white/25 animate-float-slow" aria-hidden="true" style="animation-delay: 1.5s;"></div>

  {/* Content */}
  <div class="relative z-10 max-w-3xl mx-auto text-center" data-reveal>
    {/* Support status badge */}
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-bold mb-8 bg-white/15 backdrop-blur-sm border border-white/20 text-white">
      <span
        class:list={[
          'w-2 h-2 rounded-full',
          isOpen ? 'bg-white animate-pulse' : 'bg-white/40',
        ]}
      ></span>
      {isOpen ? contact.open_label : contact.closed_label}
      <span class="text-white/60">|</span>
      <span class="text-white/80 font-normal">{contact.hours}</span>
    </div>

    <h2
      id="contact-title"
      class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-5 leading-tight"
    >
      {contact.title}
    </h2>

    <p class="text-white/80 text-base sm:text-lg mb-10 max-w-xl mx-auto leading-relaxed">
      {contact.subtitle}
    </p>

    {/* WhatsApp CTA button */}
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 px-5 sm:px-8 py-3 sm:py-4 rounded-full
             bg-white text-[#1E40AF] font-bold text-base sm:text-lg
             hover:bg-[#3B82F6] hover:text-white
             shadow-xl hover:shadow-2xl
             transition-all duration-200 hover:scale-105"
    >
      <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      {contact.cta_whatsapp}
    </a>

    {/* Email link */}
    <p class="mt-6 text-white/60 text-sm">
      {SITE.email}
    </p>
  </div>
</section>
