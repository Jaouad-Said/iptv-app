---
import { SITE } from '../../config/site';
import { useTranslations, interpolate } from '../../i18n/index';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const whyUs = t('whyUs');
const title = interpolate(whyUs.title, { brand: SITE.name });

/**
 * Bento grid layout map — defines which features get "large" (2-col span) treatment.
 * Row 1: index 0 = large, index 1 = regular
 * Row 2: index 2 = regular, index 3 = large
 * Row 3: index 4, 5 = regular (3 equal cards if 6 features)
 */
const largeIndices = new Set([0, 3]);
---

<section
  class="relative py-24 px-4 sm:px-6 overflow-hidden"
  aria-labelledby="why-us-title"
>
  <!-- Mesh gradient background -->
  <div class="absolute inset-0 mesh-gradient pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16" data-reveal>
      <h2
        id="why-us-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold"
      >
        <span class="text-gradient">{title}</span>
      </h2>
      <p class="mt-4 text-slate-500 dark:text-slate-400 text-lg max-w-2xl mx-auto">
        Everything you need for the ultimate streaming experience.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {whyUs.features.map((feature, i) => {
        const isLarge = largeIndices.has(i);
        return (
          <div
            class:list={[
              'glass-card bento-card rounded-2xl p-6 sm:p-8 relative group',
              isLarge ? 'md:col-span-2' : 'md:col-span-1',
            ]}
            data-reveal
            style={`transition-delay: ${i * 80}ms`}
          >
            {/* Green gradient accent on left border for large cards */}
            {isLarge && (
              <div
                class="absolute left-0 top-4 bottom-4 w-[3px] rounded-full bg-gradient-to-b from-[#3B82F6] via-[#60A5FA] to-[#F59E0B]"
                aria-hidden="true"
              />
            )}

            <div class:list={['flex gap-5 items-start', isLarge ? 'ps-4' : '']}>
              {/* Emoji icon in colored circle */}
              <div class:list={[
                'flex items-center justify-center shrink-0 rounded-xl',
                isLarge
                  ? 'w-14 h-14 text-2xl bg-[#3B82F6]/10 ring-1 ring-[#3B82F6]/20'
                  : 'w-12 h-12 text-xl bg-[#3B82F6]/10 ring-1 ring-[#3B82F6]/15',
              ]}>
                <span role="img" aria-hidden="true">{feature.icon}</span>
              </div>

              <div class="flex-1 min-w-0">
                <h3 class:list={[
                  'font-bold text-slate-800 dark:text-slate-100 mb-1.5',
                  isLarge ? 'text-lg sm:text-xl' : 'text-base sm:text-lg',
                ]}>
                  {feature.title}
                </h3>
                <p class:list={[
                  'text-slate-500 dark:text-slate-400 leading-relaxed',
                  isLarge ? 'text-base' : 'text-sm',
                ]}>
                  {feature.description}
                </p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Wave divider at bottom -->
  <div class="absolute -bottom-1 left-0 right-0 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 sm:h-16">
      <path d="M0,48 C480,0 960,60 1440,24 L1440,60 L0,60 Z" fill="currentColor" class="text-slate-50 dark:text-slate-900/30"/>
    </svg>
  </div>
</section>
