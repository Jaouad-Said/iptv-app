---
import { SITE } from '../../config/site';
import { NAV_LINKS } from '../../config/navigation';
import { LOCALES, LOCALE_META } from '../../config/locales';
import { useTranslations } from '../../i18n/index';
import { getWhatsAppUrl } from '../../config/whatsapp';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const waUrl = getWhatsAppUrl('default');

// Build nav href: /{lang}/path
function navHref(href: string) {
  return href ? `/${lang}/${href}` : `/${lang}/`;
}

// Build language switch href preserving current path
function langHref(targetLang: string) {
  const stripped = currentPath.replace(/^\/(en|fr|ar)/, '') || '/';
  return `/${targetLang}${stripped === '/' ? '' : stripped}`;
}

// Determine active link
function isActive(href: string) {
  return currentPath === navHref(href) || currentPath === navHref(href) + '/';
}
---

<header
  id="navbar"
  class="fixed top-0 start-0 end-0 z-[100] transition-all duration-300"
  role="banner"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 lg:h-18">

      <!-- Logo -->
      <a href={navHref('')} class="flex items-center gap-2 shrink-0" aria-label={SITE.name + ' home'}>
        <span class="text-xl font-extrabold tracking-tight text-[#3B82F6]">{SITE.name}</span>
      </a>

      <!-- Desktop nav links -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {NAV_LINKS.map(link => (
          <a
            href={navHref(link.href)}
            class:list={[
              'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors duration-150',
              isActive(link.href)
                ? 'bg-[#3B82F6]/10 text-[#3B82F6]'
                : 'text-slate-600 dark:text-slate-300 hover:text-[#3B82F6] hover:bg-[#3B82F6]/5',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {t(link.key as any)}
          </a>
        ))}
      </nav>

      <!-- Right controls -->
      <div class="flex items-center gap-2">
        <!-- Language switcher -->
        <div class="relative hidden sm:block" id="lang-dropdown-wrap">
          <button
            id="lang-btn"
            type="button"
            class="flex items-center gap-1 px-2 py-1.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300
                   hover:text-[#3B82F6] hover:bg-[#3B82F6]/5 transition-colors duration-150"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-label="Change language"
          >
            <span id="lang-flag">{LOCALE_META[lang].flag}</span>
            <span id="lang-label">{LOCALE_META[lang].label}</span>
            <svg class="w-3 h-3 ms-0.5 transition-transform duration-150" id="lang-caret" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 4l4 4 4-4"/>
            </svg>
          </button>
          <ul
            id="lang-menu"
            role="listbox"
            aria-label="Language selection"
            class="absolute end-0 mt-1 w-36 rounded-xl border border-slate-200 dark:border-slate-700
                   bg-white dark:bg-slate-900 shadow-lg py-1 hidden z-50"
          >
            {LOCALES.map(l => (
              <li role="option" aria-selected={l === lang}>
                <a
                  href={langHref(l)}
                  class:list={[
                    'flex items-center gap-2 px-3 py-2 text-sm transition-colors duration-100',
                    l === lang
                      ? 'text-[#3B82F6] font-medium bg-[#3B82F6]/5'
                      : 'text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800',
                  ]}
                >
                  <span>{LOCALE_META[l].flag}</span>
                  <span>{LOCALE_META[l].nativeName}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Dark mode toggle -->
        <button
          id="theme-btn"
          type="button"
          class="hidden sm:flex items-center justify-center w-8 h-8 rounded-lg text-slate-600 dark:text-slate-300
                 hover:text-[#3B82F6] hover:bg-[#3B82F6]/5 transition-colors duration-150"
          aria-label="Toggle dark mode"
        >
          <svg id="icon-sun" class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg id="icon-moon" class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>

        <!-- WhatsApp CTA (desktop) -->
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#3B82F6] text-white text-sm font-semibold
                 hover:brightness-110 transition-all duration-150 shadow-[var(--shadow-button)]"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          WhatsApp
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="lg:hidden flex items-center justify-center w-8 h-8 rounded-lg text-slate-600 dark:text-slate-300
                 hover:text-[#3B82F6] hover:bg-[#3B82F6]/5 transition-colors duration-150"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-menu" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-slate-200/70 dark:border-slate-800 bg-white/95 dark:bg-slate-950/95 backdrop-blur-md"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1">
      {NAV_LINKS.map(link => (
        <a
          href={navHref(link.href)}
          class:list={[
            'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors duration-150',
            isActive(link.href)
              ? 'bg-[#3B82F6]/10 text-[#3B82F6]'
              : 'text-slate-600 dark:text-slate-300 hover:text-[#3B82F6] hover:bg-[#3B82F6]/5',
          ]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {t(link.key as any)}
        </a>
      ))}

      <!-- Language + theme row -->
      <div class="flex items-center gap-2 pt-2 border-t border-slate-200/70 dark:border-slate-800 mt-2">
        {LOCALES.map(l => (
          <a
            href={langHref(l)}
            class:list={[
              'flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-sm font-medium transition-colors duration-100',
              l === lang
                ? 'bg-[#3B82F6]/10 text-[#3B82F6]'
                : 'text-slate-600 dark:text-slate-300 hover:text-[#3B82F6] hover:bg-[#3B82F6]/5',
            ]}
          >
            <span>{LOCALE_META[l].flag}</span>
            <span>{LOCALE_META[l].label}</span>
          </a>
        ))}
        <button
          id="theme-btn-mobile"
          type="button"
          class="ms-auto flex items-center justify-center w-8 h-8 rounded-lg text-slate-600 dark:text-slate-300
                 hover:text-[#3B82F6] hover:bg-[#3B82F6]/5 transition-colors duration-150"
          aria-label="Toggle dark mode"
        >
          <svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>

      <!-- WhatsApp CTA mobile -->
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 flex items-center justify-center gap-2 px-4 py-3 rounded-full bg-[#3B82F6] text-white text-sm font-semibold"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Contact on WhatsApp
      </a>
    </div>
  </div>
</header>

<!-- Navbar spacer -->
<div class="h-16 lg:h-18" aria-hidden="true"></div>

<script>
  // Navbar scroll behavior
  const navbar = document.getElementById('navbar')!;
  function updateNavbar() {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-white/80', 'dark:bg-slate-950/80', 'backdrop-blur-md',
        'border-b', 'border-slate-200/70', 'dark:border-slate-800/70', 'shadow-sm');
    } else {
      navbar.classList.remove('bg-white/80', 'dark:bg-slate-950/80', 'backdrop-blur-md',
        'border-b', 'border-slate-200/70', 'dark:border-slate-800/70', 'shadow-sm');
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  function closeMobileMenu() {
    mobileMenu.classList.add('hidden');
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');
    mobileBtn.setAttribute('aria-expanded', 'false');
  }

  mobileBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    if (isOpen) {
      closeMobileMenu();
    } else {
      mobileMenu.classList.remove('hidden');
      iconMenu.classList.add('hidden');
      iconClose.classList.remove('hidden');
      mobileBtn.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
      closeMobileMenu();
      mobileBtn.focus();
    }
  });

  // Language dropdown
  const langBtn = document.getElementById('lang-btn');
  const langMenu = document.getElementById('lang-menu');
  const langCaret = document.getElementById('lang-caret');

  if (langBtn && langMenu && langCaret) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isHidden = langMenu.classList.contains('hidden');
      langMenu.classList.toggle('hidden', !isHidden);
      langBtn.setAttribute('aria-expanded', String(isHidden));
      langCaret.style.transform = isHidden ? 'rotate(180deg)' : '';
    });
    document.addEventListener('click', () => {
      langMenu.classList.add('hidden');
      langBtn.setAttribute('aria-expanded', 'false');
      langCaret.style.transform = '';
    });
  }

  // Dark mode toggle
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('iptv_theme', isDark ? 'dark' : 'light'); } catch {}
  }

  document.getElementById('theme-btn')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-btn-mobile')?.addEventListener('click', toggleTheme);
</script>
