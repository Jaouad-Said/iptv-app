---
import { SITE } from '../../config/site';
import { getWhatsAppUrl } from '../../config/whatsapp';
import { useTranslations, interpolate } from '../../i18n/index';
import {
  PLAN_FEATURES_BASE,
  PLAN_FEATURES_EXTRA,
  type Plan,
} from '../../config/plans';
import type { Locale } from '../../config/locales';

interface Props {
  plan: Plan;
  lang: Locale;
}

const { plan, lang } = Astro.props;
const t = useTranslations(lang);
const plansT = t('plans');
const waUrl = getWhatsAppUrl(plan.waMessageKey);

const devicesLabel = plan.devicesCount
  ? interpolate(plansT.devices, { count: plan.devicesCount })
  : null;

const monthlyEquivalent =
  plan.durationMonths > 1
    ? `${(plan.priceEUR / plan.durationMonths).toFixed(2)}${SITE.currencySymbol}${plansT.per_month}`
    : null;
---

<div
  class:list={[
    'plan-card group relative flex flex-col rounded-2xl border p-6 pt-8 bg-white dark:bg-slate-900 overflow-hidden',
    plan.isBestValue
      ? 'plan-card-featured border-[#3B82F6]'
      : 'border-slate-200 dark:border-slate-800',
  ]}
>
  {/* Green gradient top border accent for featured card */}
  {plan.isBestValue && (
    <div
      class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[#3B82F6] via-[#60A5FA] to-[#F59E0B]"
      aria-hidden="true"
    ></div>
  )}

  {/* Best Value badge */}
  {plan.isBestValue && (
    <div class="absolute -top-0 start-1/2 -translate-x-1/2 rtl:translate-x-1/2 translate-y-2">
      <span
        class="badge-shine relative inline-flex items-center gap-1 px-4 py-1.5 rounded-full
               bg-[#3B82F6] text-white text-xs font-bold shadow-lg whitespace-nowrap"
      >
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {plansT.best_value}
      </span>
    </div>
  )}

  {/* Duration label */}
  <div class:list={['mb-3', plan.isBestValue && 'mt-4']}>
    <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">
      {plan.durationLabel}
    </p>
  </div>

  {/* Plan badge (e.g. "FREE app activation included") */}
  {plan.badge && (
    <span
      class="inline-flex self-start items-center px-3 py-1 mb-3 rounded-full
             bg-[#3B82F6]/10 text-[#3B82F6] text-xs font-semibold border border-[#3B82F6]/20"
    >
      {plan.badge}
    </span>
  )}

  {/* Devices count badge (multi-type only) */}
  {devicesLabel && (
    <span
      class="inline-flex self-start items-center gap-1.5 px-3 py-1 mb-3 rounded-full
             bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-semibold"
    >
      <svg class="w-3.5 h-3.5 text-[#3B82F6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
        <line x1="8" y1="21" x2="16" y2="21"/>
        <line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
      {devicesLabel}
    </span>
  )}

  {/* Price block */}
  <div class="mb-5">
    {plan.originalPriceEUR && (
      <span class="text-sm text-slate-400 line-through me-2">
        {plansT.original_price} {SITE.currencySymbol}{plan.originalPriceEUR}
      </span>
    )}
    <div class="flex items-baseline gap-1 mt-1">
      <span class="text-3xl sm:text-4xl font-extrabold text-gradient">
        {SITE.currencySymbol}{plan.priceEUR}
      </span>
      {monthlyEquivalent && (
        <span class="text-xs text-slate-400 ms-1">{monthlyEquivalent}</span>
      )}
    </div>
  </div>

  {/* CTA Button — opens order form */}
  <button
    type="button"
    class:list={[
      'order-btn flex items-center justify-center gap-2 w-full py-3.5 rounded-full font-semibold text-sm transition-all duration-200 cursor-pointer',
      plan.isBestValue
        ? 'bg-[#3B82F6] text-white hover:brightness-110 shadow-[var(--shadow-button)] hover:shadow-lg'
        : 'bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-[#3B82F6] dark:hover:bg-[#3B82F6] hover:text-white dark:hover:text-white',
    ]}
    data-plan-name={`${plan.durationLabel}${plan.devicesCount ? ` (${plan.devicesCount} devices)` : ''}`}
    data-plan-price={`${SITE.currencySymbol}${plan.priceEUR}`}
    data-wa-url={waUrl}
  >
    <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    {plansT.get_package}
  </button>

  {/* Instant activation label */}
  <p class="flex items-center justify-center gap-1.5 mt-3 mb-5 text-xs text-slate-400">
    <svg class="w-3.5 h-3.5 text-[#3B82F6] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    {plansT.instant_activation}
  </p>

  {/* Divider */}
  <div class="border-t border-slate-100 dark:border-slate-800 mb-4"></div>

  {/* Base features */}
  <ul class="space-y-2.5 mb-4">
    {PLAN_FEATURES_BASE.map((key) => (
      <li class="flex items-start gap-2.5 text-xs text-slate-600 dark:text-slate-300">
        <svg
          class="w-4 h-4 text-[#3B82F6] mt-0.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
        <span>
          {t('plans').features[key.replace('plans.features.', '') as keyof typeof plansT.features]}
        </span>
      </li>
    ))}
  </ul>

  {/* Expandable extra features */}
  <details class="group mt-auto">
    <summary class="flex items-center gap-1.5 text-xs text-[#3B82F6] font-medium cursor-pointer hover:underline list-none select-none">
      <span class="group-open:hidden">{plansT.more_details}</span>
      <span class="hidden group-open:block">{plansT.less_details}</span>
      <svg
        class="w-3 h-3 transition-transform duration-200 group-open:rotate-180"
        viewBox="0 0 12 12"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M2 4l4 4 4-4" />
      </svg>
    </summary>
    <ul class="mt-3 space-y-2.5">
      {PLAN_FEATURES_EXTRA.map((key) => (
        <li class="flex items-start gap-2.5 text-xs text-slate-500 dark:text-slate-400">
          <svg
            class="w-4 h-4 text-slate-400 dark:text-slate-500 mt-0.5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <span>
            {t('plans').features[key.replace('plans.features.', '') as keyof typeof plansT.features]}
          </span>
        </li>
      ))}
    </ul>
  </details>
</div>
