---
import { useTranslations } from '../../i18n/index';
import { SINGLE_PLANS, MULTI_PLANS } from '../../config/plans';
import PlanCard from './PlanCard.astro';
import type { Locale } from '../../config/locales';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const plansT = t('plans');
---

<section
  id="pricing"
  class="py-24 px-4 mesh-gradient bg-slate-50 dark:bg-slate-900/30"
  aria-labelledby="pricing-title"
>
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14" data-reveal>
      <h2
        id="pricing-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-800 dark:text-slate-100 mb-4"
      >
        <span class="text-gradient">{plansT.title}</span>
      </h2>
      <p
        id="pricing-subtitle"
        class="text-slate-500 dark:text-slate-400 text-base sm:text-lg max-w-2xl mx-auto leading-relaxed"
      >
        {plansT.subtitle_single}
      </p>
    </div>

    <!-- Tab switcher -->
    <div class="flex justify-center mb-12" data-reveal>
      <div class="relative inline-flex p-1 rounded-full bg-slate-200/80 dark:bg-slate-800 gap-0" role="tablist" aria-label={plansT.title}>
        {/* Sliding pill indicator */}
        <div
          id="tab-pill"
          class="absolute top-1 bottom-1 rounded-full bg-white dark:bg-slate-700 shadow-md transition-all duration-300 ease-out"
          aria-hidden="true"
          style="left: 4px; width: calc(50% - 4px);"
        ></div>

        <button
          id="tab-single"
          type="button"
          role="tab"
          aria-selected="true"
          aria-controls="panel-single"
          tabindex="0"
          class="relative z-10 px-5 sm:px-6 py-2.5 rounded-full text-sm font-semibold transition-colors duration-200
                 text-slate-800 dark:text-slate-100"
          data-target="panel-single"
          data-subtitle={plansT.subtitle_single}
        >
          {plansT.tab_single}
        </button>
        <button
          id="tab-multi"
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="panel-multi"
          tabindex="-1"
          class="relative z-10 px-5 sm:px-6 py-2.5 rounded-full text-sm font-semibold transition-colors duration-200
                 text-slate-500 dark:text-slate-400"
          data-target="panel-multi"
          data-subtitle={plansT.subtitle_multi}
        >
          {plansT.tab_multi}
        </button>
      </div>
    </div>

    <!-- Single plans panel -->
    <div id="panel-single" role="tabpanel" aria-labelledby="tab-single" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {SINGLE_PLANS.map((plan) => (
        <PlanCard plan={plan} lang={lang} />
      ))}
    </div>

    <!-- Multi plans panel (hidden by default) -->
    <div id="panel-multi" role="tabpanel" aria-labelledby="tab-multi" class="hidden max-w-5xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {MULTI_PLANS.map((plan) => (
          <PlanCard plan={plan} lang={lang} />
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Order Form Modal -->
<div id="order-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="order-modal-title">
  <div class="relative w-full max-w-md bg-white dark:bg-slate-900 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 p-6 sm:p-8">
    <!-- Close button -->
    <button id="order-modal-close" type="button" class="absolute top-4 right-4 p-1.5 rounded-lg text-slate-400 hover:text-slate-600 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="Close">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <!-- Header -->
    <div class="mb-6">
      <h3 id="order-modal-title" class="text-xl font-bold text-slate-900 dark:text-white">Place Your Order</h3>
      <p id="order-modal-plan" class="text-sm text-[#3B82F6] font-medium mt-1"></p>
    </div>

    <!-- Form -->
    <form id="order-form" class="space-y-4">
      <div>
        <label for="order-name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Full Name</label>
        <input id="order-name" type="text" required placeholder="Your name"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#3B82F6] focus:border-transparent" />
      </div>
      <div>
        <label for="order-email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
        <input id="order-email" type="email" required placeholder="your@email.com"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#3B82F6] focus:border-transparent" />
      </div>
      <div>
        <label for="order-phone" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Phone / WhatsApp Number</label>
        <input id="order-phone" type="tel" placeholder="+1 234 567 890"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#3B82F6] focus:border-transparent" />
      </div>

      <input type="hidden" id="order-wa-url" value="" />

      <!-- Submit -->
      <button type="submit"
        class="w-full flex items-center justify-center gap-2 py-3.5 rounded-full bg-[#25D366] text-white font-semibold text-sm hover:brightness-110 shadow-lg shadow-[#25D366]/25 transition-all">
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Complete Order via WhatsApp
      </button>
    </form>
  </div>
</div>

<script>
  function initPricingTabs() {
    const tabSingle = document.getElementById('tab-single') as HTMLButtonElement | null;
    const tabMulti = document.getElementById('tab-multi') as HTMLButtonElement | null;
    const pill = document.getElementById('tab-pill') as HTMLElement | null;
    const subtitle = document.getElementById('pricing-subtitle') as HTMLElement | null;
    const panelSingle = document.getElementById('panel-single') as HTMLElement | null;
    const panelMulti = document.getElementById('panel-multi') as HTMLElement | null;

    if (!tabSingle || !tabMulti || !pill || !subtitle || !panelSingle || !panelMulti) return;

    const tabs = [tabSingle, tabMulti];

    function activate(activeTab: HTMLButtonElement) {
      const isSingle = activeTab === tabSingle;

      // Move the pill indicator
      if (isSingle) {
        pill!.style.left = '4px';
        pill!.style.width = `calc(50% - 4px)`;
      } else {
        pill!.style.left = '50%';
        pill!.style.width = `calc(50% - 4px)`;
      }

      // Update tab ARIA and text styles
      tabs.forEach((t) => {
        const isActive = t === activeTab;
        t.classList.toggle('text-slate-800', isActive);
        t.classList.toggle('dark:text-slate-100', isActive);
        t.classList.toggle('text-slate-500', !isActive);
        t.classList.toggle('dark:text-slate-400', !isActive);
        t.setAttribute('aria-selected', String(isActive));
        t.setAttribute('tabindex', isActive ? '0' : '-1');
      });

      // Swap subtitle text
      subtitle!.textContent = activeTab.dataset.subtitle ?? '';

      // Toggle panel visibility
      panelSingle!.classList.toggle('hidden', !isSingle);
      panelMulti!.classList.toggle('hidden', isSingle);
    }

    tabSingle.addEventListener('click', () => activate(tabSingle));
    tabMulti.addEventListener('click', () => activate(tabMulti));

    // Arrow key navigation between tabs
    tabs.forEach((tab) => {
      tab.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        let target: HTMLButtonElement | null = null;
        if (key === 'ArrowRight' || key === 'ArrowDown') target = tab === tabSingle ? tabMulti : tabSingle;
        if (key === 'ArrowLeft' || key === 'ArrowUp') target = tab === tabMulti ? tabSingle : tabMulti;
        if (target) {
          e.preventDefault();
          activate(target);
          target.focus();
        }
      });
    });
  }

  // Init on first load and subsequent navigations (Astro view transitions)
  initPricingTabs();
  document.addEventListener('astro:after-swap', initPricingTabs);

  // ─── Order Modal ────────────────────────────────────────────────────────────
  function initOrderModal() {
    const modal = document.getElementById('order-modal');
    const closeBtn = document.getElementById('order-modal-close');
    const planLabel = document.getElementById('order-modal-plan');
    const form = document.getElementById('order-form') as HTMLFormElement | null;
    const waUrlInput = document.getElementById('order-wa-url') as HTMLInputElement | null;

    if (!modal || !form || !waUrlInput) return;

    let currentPlanName = '';
    let currentPlanPrice = '';

    // Open modal from any order button
    document.querySelectorAll('.order-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentPlanName = (btn as HTMLElement).dataset.planName || '';
        currentPlanPrice = (btn as HTMLElement).dataset.planPrice || '';
        const waUrl = (btn as HTMLElement).dataset.waUrl || '';
        waUrlInput.value = waUrl;
        if (planLabel) planLabel.textContent = `${currentPlanName} — ${currentPlanPrice}`;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        (document.getElementById('order-name') as HTMLInputElement)?.focus();
      });
    });

    // Close modal
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      form.reset();
    }

    closeBtn?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });

    // Submit form → build WhatsApp message with customer details
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('order-name') as HTMLInputElement)?.value || '';
      const email = (document.getElementById('order-email') as HTMLInputElement)?.value || '';
      const phone = (document.getElementById('order-phone') as HTMLInputElement)?.value || '';

      // Build message from base WA URL (extract the number)
      const baseUrl = waUrlInput.value;
      const waNumber = baseUrl.match(/wa\.me\/(\d+)/)?.[1] || '';

      const msg = [
        `Hello! I'd like to place an order.`,
        ``,
        `Plan: ${currentPlanName}`,
        `Price: ${currentPlanPrice}`,
        `Name: ${name}`,
        `Email: ${email}`,
        phone ? `Phone: ${phone}` : '',
      ].filter(Boolean).join('\n');

      const orderUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`;
      window.open(orderUrl, '_blank', 'noopener,noreferrer');
      closeModal();
    });
  }

  initOrderModal();
  document.addEventListener('astro:after-swap', initOrderModal);
</script>
